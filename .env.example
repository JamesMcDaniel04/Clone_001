# Copy to .env.local and fill in. These are SERVER-SIDE secrets — they are read
# only by the /api functions and are NEVER bundled into the browser (no VITE_
# prefix). For production, set the same variables in the Vercel dashboard
# (Settings → Environment Variables).

# ── Anthropic ────────────────────────────────────────────────────────────────
# Create a key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...
# Draft model. Default (if unset) is claude-opus-4-8 — best accuracy for
# security/legal drafting. Switch to claude-sonnet-4-6 for ~40% lower cost/faster.
ANTHROPIC_MODEL=claude-opus-4-8

# ── Answer library (Google Doc published to web as plain text) ───────────────
# In Google Docs: File → Share → Publish to web → Plain text → copy the URL.
# It looks like: https://docs.google.com/document/d/XXXX/pub?output=txt
# Leave blank to use the bundled fallback library in api/_lib/library.js.
LIBRARY_DOC_URL=

# ── Airtable (optional — history & tracking) ─────────────────────────────────
# Personal access token with scopes data.records:read + data.records:write.
# Base id is the appXXXXXXXX part of the base URL.
# Leave blank to run without history (drafting/export still work).
AIRTABLE_TOKEN=
AIRTABLE_BASE=
# Table names — defaults match docs/AIRTABLE_SCHEMA.md. Override only if renamed.
AIRTABLE_QUESTIONNAIRES_TABLE=Questionnaires
AIRTABLE_QUESTIONS_TABLE=Questions
AIRTABLE_LIBRARY_TABLE=Answer Library
AIRTABLE_FLAGS_TABLE=Flags log
