# Copy to .env.local and fill in. Two classes of variables:
#  • VITE_* are exposed to the browser (safe: Supabase anon key is public by design,
#    protected by Row-Level Security).
#  • Everything without VITE_ is server-only (read by /api functions, never bundled).
# For production, set the same variables in the Vercel dashboard.

# ── Supabase (system of record: DB + auth) ───────────────────────────────────
# Create a project at https://supabase.com → Project Settings → API
VITE_SUPABASE_URL=https://YOURPROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...
# Restrict sign-in to one email domain (e.g. people.ai). Leave blank to allow any Google account.
VITE_ALLOWED_EMAIL_DOMAIN=

# Server-side Supabase access for the drafting API (grounds Claude on the live library).
# Service role key — SECRET, never prefix with VITE_. Settings → API → service_role.
SUPABASE_URL=https://YOURPROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# Draft model. Default (if unset) is claude-opus-4-8. Use claude-sonnet-4-6 for cheaper/faster.
ANTHROPIC_MODEL=claude-opus-4-8

# ── Optional fallback library ────────────────────────────────────────────────
# If Supabase has no entries yet, the drafting API falls back to this published Google Doc,
# then to the bundled library in api/_lib/library.js. Usually leave blank once Supabase is seeded.
LIBRARY_DOC_URL=
