# TEMPLATE ONLY — do not put real keys here. This file is committed to git.
# Put your real values in `.env` (which is gitignored). Copy this file:  cp .env.example .env
#
# Two classes of variables:
#  • VITE_*  → exposed to the browser (safe: the Supabase anon/publishable key is public
#              by design, protected by Row-Level Security). NOTE: Vite uses the VITE_ prefix,
#              NOT Next.js's NEXT_PUBLIC_ prefix.
#  • no prefix → server-only (read by /api functions and `vite dev`), never bundled to the browser.

# ── Supabase: browser (client) ───────────────────────────────────────────────
# Project Settings → API. The anon key is the "Publishable key" (sb_publishable_…) on new
# projects, or the long "anon public" JWT (eyJ…) on older ones.
VITE_SUPABASE_URL=https://YOURPROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=
# Restrict sign-in to one email domain (e.g. people.ai). Blank = any Google account.
VITE_ALLOWED_EMAIL_DOMAIN=
# TEMPORARY no-login test mode. true = skip Google sign-in and use an anonymous
# session instead (so the DB works with no login). Requires enabling Anonymous
# Sign-Ins in Supabase → Authentication. Set back to false before real deployment.
VITE_DISABLE_AUTH=

# ── Supabase: server (drafting API reads the live library) ───────────────────
# Use the SECRET key (sb_secret_…) here — it bypasses RLS. Project Settings → API → Secret keys.
SUPABASE_URL=https://YOURPROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# Default (if unset) is claude-opus-4-8. Use claude-sonnet-4-6 for cheaper/faster.
ANTHROPIC_MODEL=claude-opus-4-8

# ── Optional fallback library ────────────────────────────────────────────────
LIBRARY_DOC_URL=
